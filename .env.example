NEXT_PUBLIC_APP_NAME=Hito Running

# Required on Vercel for the live Supabase-backed auth/session path.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-supabase-publishable-key

# Legacy Vite aliases remain supported for compatibility, but new setup should use NEXT_PUBLIC_*.
VITE_APP_NAME=Hito Running
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Optional server-only override. Leave unset on Vercel to derive auth callback origin from the incoming request.
APP_BASE_URL=http://localhost:8080

# Server-only and currently optional for the implemented runtime. Keep unset unless a later backend change explicitly needs service-role access.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Temporary local-only account-backed auth bypass. Do not use on Vercel or as the final auth architecture.
LOCAL_AUTH_BYPASS_ENABLED=false
LOCAL_AUTH_BYPASS_ACCOUNTS_FILE=.tanstack/hito-running-local-accounts.json

# Legacy single-account fallback remains supported for compatibility, but new local setup should prefer LOCAL_AUTH_BYPASS_ACCOUNTS_FILE.
LOCAL_AUTH_BYPASS_IDENTIFIER=single-user-name
LOCAL_AUTH_BYPASS_PASSWORD=change-me-locally
LOCAL_AUTH_BYPASS_EMAIL=single-user@example.local
LOCAL_AUTH_BYPASS_USER_ID=11111111-1111-4111-8111-111111111111
LOCAL_AUTH_BYPASS_STATE_PATH=.tanstack/hito-running-local-auth.json

OPENAI_API_KEY=your-openai-api-key
