NEXT_PUBLIC_APP_NAME=Hito Running

# Local development and QA use the repo's loopback Supabase stack.
# Run npx --yes supabase@2.109.1 start, then npm run supabase:local:configure.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Optional server-only non-loopback override for auth redirects.
# Leave unset when the incoming runtime request already has the correct public host.
# For local loopback development, prefer leaving this unset so auth stays on the local origin.
# APP_BASE_URL=https://your-app.example.com

# Server-only. The local value is written to .env.local by supabase:local:configure.
# Hosted deployment credentials belong in the deployment environment, never the local default.
SUPABASE_SECRET_KEY=

# Server-only. Required for deployed /admin/login. The admin username is always "admin".
# Store a password hash, never plaintext. Generate one with:
# node -e 'const {randomBytes,pbkdf2Sync}=require("node:crypto"); const password=process.argv[1]; const salt=randomBytes(16); const iterations=310000; const hash=pbkdf2Sync(password,salt,iterations,32,"sha256"); console.log(`pbkdf2_sha256$${iterations}$${salt.toString("base64url")}$${hash.toString("base64url")}`);' 'replace-with-admin-password'
HITO_ADMIN_PASSWORD_HASH=pbkdf2_sha256$310000$replace-salt$replace-hash
HITO_ADMIN_SESSION_SECRET=replace-with-long-random-server-secret

# Temporary local-only account-backed auth bypass. Do not use on Vercel or as the final auth architecture.
LOCAL_AUTH_BYPASS_ENABLED=true
LOCAL_AUTH_BYPASS_ACCOUNTS_FILE=.tanstack/hito-running-local-accounts.json

# The managed local server uses the real provider mode by default. Never persist fixture mode in
# .env.local; start it explicitly with:
# npm run qa:server:start -- --provider-mode qa_fixture
# Optional completion delay applies only to that explicit disposable-QA runtime.
# HITO_AI_GENERATED_PLAN_DEV_FIXTURE_DELAY_MS=125000

OPENAI_API_KEY=your-openai-api-key
# Optional server-only override for the text-to-plan model. Defaults to gpt-5 when unset.
OPENAI_PLAN_MODEL=gpt-5

# Optional server-only overrides for AI-authored first-plan review.
# Product generation waits for one complete provider result; bounded CLI/smoke commands pass
# their own explicit timeout instead of imposing a local product deadline.
OPENAI_FIRST_PLAN_MODEL=gpt-4.1-mini
OPENAI_FIRST_PLAN_MAX_OUTPUT_TOKENS=32000
